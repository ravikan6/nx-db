{
    "module": "auth",
    "filters": [
        {
            "name": "encrypt",
            "decodedType": "String",
            "encodedType": "String",
            "encode": "crate::filters::encrypt",
            "decode": "crate::filters::decrypt"
        },
        {
            "name": "userSearch",
            "decodedType": "String",
            "encodedType": "String",
            "encode": "crate::filters::normalize_search",
            "decode": "crate::filters::identity"
        }
    ],
    "collections": [
        {
            "id": "users",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Users",
            "attributes": [
                {
                    "id": "name",
                    "kind": "string",
                    "length": 256
                },
                {
                    "id": "email",
                    "kind": "string",
                    "length": 320
                },
                {
                    "id": "phone",
                    "kind": "string",
                    "length": 16
                },
                {
                    "id": "status",
                    "kind": "boolean"
                },
                {
                    "id": "labels",
                    "kind": "string",
                    "array": true,
                    "length": 128
                },
                {
                    "id": "passwordHistory",
                    "kind": "string",
                    "array": true
                },
                {
                    "id": "password",
                    "kind": "string",
                    "filters": [
                        "encrypt"
                    ]
                },
                {
                    "id": "hash",
                    "kind": "string",
                    "length": 256
                },
                {
                    "id": "hashOptions",
                    "kind": "json"
                },
                {
                    "id": "passwordUpdate",
                    "kind": "timestamp"
                },
                {
                    "id": "prefs",
                    "kind": "json"
                },
                {
                    "id": "registration",
                    "kind": "timestamp"
                },
                {
                    "id": "emailVerification",
                    "kind": "boolean"
                },
                {
                    "id": "phoneVerification",
                    "kind": "boolean"
                },
                {
                    "id": "reset",
                    "kind": "boolean"
                },
                {
                    "id": "mfa",
                    "kind": "boolean"
                },
                {
                    "id": "mfaRecoveryCodes",
                    "kind": "string",
                    "filters": [
                        "encrypt"
                    ]
                },
                {
                    "id": "search",
                    "kind": "string",
                    "filters": [
                        "userSearch"
                    ]
                },
                {
                    "id": "accessedAt",
                    "kind": "timestamp"
                },
                {
                    "id": "sessions",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "sessions",
                        "kind": "onetomany",
                        "side": "parent",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                },
                {
                    "id": "tokens",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "tokens",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                },
                {
                    "id": "authenticators",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "authenticators",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                },
                {
                    "id": "challenges",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "challenges",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                },
                {
                    "id": "identities",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "identities",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                },
                {
                    "id": "memberships",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "memberships",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                },
                {
                    "id": "targets",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "targets",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "user"
                    }
                }
            ],
            "indexes": [
                {
                    "id": "_key_email",
                    "kind": "unique",
                    "attributes": [
                        "email"
                    ],
                    "orders": [
                        "asc"
                    ]
                },
                {
                    "id": "_key_phone",
                    "kind": "unique",
                    "attributes": [
                        "phone"
                    ],
                    "orders": [
                        "asc"
                    ]
                },
                {
                    "id": "_key_search",
                    "kind": "fulltext",
                    "attributes": [
                        "search"
                    ]
                }
            ]
        },
        {
            "id": "teams",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Teams",
            "attributes": [
                {
                    "id": "name",
                    "kind": "string",
                    "length": 128
                },
                {
                    "id": "total",
                    "kind": "integer"
                },
                {
                    "id": "search",
                    "kind": "string"
                },
                {
                    "id": "prefs",
                    "kind": "json"
                },
                {
                    "id": "memberships",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "memberships",
                        "kind": "onetomany",
                        "twoWay": true,
                        "twoWayKey": "team"
                    }
                }
            ],
            "indexes": [
                {
                    "id": "_key_search",
                    "kind": "fulltext",
                    "attributes": [
                        "search"
                    ]
                }
            ]
        },
        {
            "id": "sessions",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Sessions",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer",
                    "required": true
                },
                {
                    "id": "userId",
                    "kind": "string",
                    "length": 255
                },
                {
                    "id": "provider",
                    "kind": "string",
                    "length": 128
                },
                {
                    "id": "providerUid",
                    "kind": "string",
                    "length": 2048
                },
                {
                    "id": "secret",
                    "kind": "string",
                    "filters": [
                        "encrypt"
                    ],
                    "length": 512
                },
                {
                    "id": "userAgent",
                    "kind": "string"
                },
                {
                    "id": "ip",
                    "kind": "string",
                    "length": 45
                },
                {
                    "id": "expire",
                    "kind": "timestamp",
                    "required": true
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "side": "child",
                        "twoWay": true,
                        "twoWayKey": "sessions",
                        "onDelete": "cascade"
                    }
                }
            ]
        },
        {
            "id": "tokens",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Tokens",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer",
                    "required": true
                },
                {
                    "id": "userId",
                    "kind": "string",
                    "length": 255
                },
                {
                    "id": "kind",
                    "kind": "integer",
                    "required": true
                },
                {
                    "id": "secret",
                    "kind": "string",
                    "filters": [
                        "encrypt"
                    ],
                    "length": 1000
                },
                {
                    "id": "expire",
                    "kind": "timestamp"
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "tokens",
                        "onDelete": "cascade"
                    }
                }
            ]
        },
        {
            "id": "authenticators",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Authenticators",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer"
                },
                {
                    "id": "kind",
                    "kind": "string",
                    "length": 255
                },
                {
                    "id": "verified",
                    "kind": "boolean"
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "authenticators"
                    }
                }
            ]
        },
        {
            "id": "challenges",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Challenges",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer"
                },
                {
                    "id": "kind",
                    "kind": "string",
                    "length": 255
                },
                {
                    "id": "expire",
                    "kind": "timestamp"
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "challenges"
                    }
                }
            ]
        },
        {
            "id": "identities",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Identities",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer"
                },
                {
                    "id": "provider",
                    "kind": "string",
                    "length": 128
                },
                {
                    "id": "providerUid",
                    "kind": "string",
                    "length": 2048
                },
                {
                    "id": "providerEmail",
                    "kind": "string",
                    "length": 320
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "identities"
                    }
                }
            ]
        },
        {
            "id": "memberships",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Memberships",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer",
                    "required": true
                },
                {
                    "id": "teamInternalId",
                    "kind": "integer",
                    "required": true
                },
                {
                    "id": "roles",
                    "kind": "string",
                    "array": true,
                    "length": 128
                },
                {
                    "id": "invited",
                    "kind": "timestamp"
                },
                {
                    "id": "joined",
                    "kind": "timestamp"
                },
                {
                    "id": "confirm",
                    "kind": "boolean"
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "memberships",
                        "onDelete": "cascade"
                    }
                },
                {
                    "id": "team",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "teams",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "memberships",
                        "onDelete": "cascade"
                    }
                }
            ]
        },
        {
            "id": "targets",
            "permissions": [
                "create(\"any\")"
            ],
            "name": "Targets",
            "attributes": [
                {
                    "id": "userInternalId",
                    "kind": "integer",
                    "required": true
                },
                {
                    "id": "providerType",
                    "kind": "string",
                    "required": true,
                    "length": 255
                },
                {
                    "id": "identifier",
                    "kind": "string",
                    "required": true,
                    "length": 255
                },
                {
                    "id": "expired",
                    "kind": "boolean"
                },
                {
                    "id": "user",
                    "kind": "relationship",
                    "relationship": {
                        "relatedCollection": "users",
                        "kind": "manytoone",
                        "twoWay": true,
                        "twoWayKey": "targets",
                        "onDelete": "cascade"
                    }
                }
            ]
        }
    ]
}
