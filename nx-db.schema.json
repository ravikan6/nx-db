{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nx-db Project Schema",
  "type": "object",
  "required": ["collections"],
  "properties": {
    "module": {
      "type": "string",
      "description": "The name of the generated Rust module"
    },
    "filters": {
      "type": "array",
      "items": { "$ref": "#/definitions/filter" }
    },
    "resolvers": {
      "type": "array",
      "items": { "$ref": "#/definitions/resolver" }
    },
    "collections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/collection" }
    }
  },
  "definitions": {
    "filter": {
      "type": "object",
      "required": ["name", "decodedType", "encodedType", "encode", "decode"],
      "properties": {
        "name": { "type": "string" },
        "decodedType": { "type": "string" },
        "encodedType": { "type": "string" },
        "encode": { "type": "string" },
        "decode": { "type": "string" }
      }
    },
    "resolver": {
      "type": "object",
      "required": ["name", "outputType", "resolve"],
      "properties": {
        "name": { "type": "string" },
        "outputType": { "type": "string" },
        "resolve": { "type": "string" }
      }
    },
    "collection": {
      "type": "object",
      "required": ["id", "name", "attributes"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "model": { "type": "string" },
        "documentSecurity": { "type": "boolean", "default": true },
        "permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "idMaxLength": { "type": "integer", "default": 255, "minimum": 36 },
        "indexes": {
          "type": "array",
          "items": { "$ref": "#/definitions/index" }
        },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/definitions/attribute" }
        }
      }
    },
    "attribute": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "column": { "type": "string" },
        "length": { "type": "integer" },
        "kind": {
          "type": "string",
          "enum": [
            "string",
            "integer",
            "float",
            "boolean",
            "timestamp",
            "relationship",
            "virtual",
            "json",
            "enum"
          ]
        },
        "elements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required": { "type": "boolean", "default": false },
        "array": { "type": "boolean", "default": false },
        "filters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolver": { "type": "string" },
        "relationship": { "$ref": "#/definitions/relationship" }
      }
    },
    "relationship": {
      "type": "object",
      "required": ["relatedCollection"],
      "properties": {
        "relatedCollection": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["onetoone", "onetomany", "manytoone", "manytomany"],
          "default": "onetoone"
        },
        "side": {
          "type": "string",
          "enum": ["parent", "child"],
          "default": "parent"
        },
        "twoWay": { "type": "boolean", "default": false },
        "twoWayKey": { "type": "string" },
        "throughCollection": { "type": "string" },
        "throughLocalField": { "type": "string" },
        "throughRemoteField": { "type": "string" },
        "onDelete": {
          "type": "string",
          "enum": ["setnull", "cascade", "restrict"],
          "default": "restrict"
        }
      }
    },
    "index": {
      "type": "object",
      "required": ["id", "kind", "attributes"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["key", "unique", "fulltext", "spatial"]
        },
        "attributes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "orders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["asc", "desc", "none"]
          }
        }
      }
    }
  }
}
