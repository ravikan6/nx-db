{
  "module": "prod_models",
  "collections": [
    {
      "id": "users",
      "name": "Users",
      "documentSecurity": true,
      "permissions": ["read(\"any\")", "create(\"any\")"],
      "idMaxLength": 48,
      "attributes": [
        { "id": "name", "kind": "string", "required": true },
        { "id": "email", "kind": "string", "required": true },
        { "id": "metadata", "kind": "json" }
      ],
      "indexes": [
        {
          "id": "users_email_unique",
          "kind": "unique",
          "attributes": ["email"]
        }
      ]
    },
    {
      "id": "posts",
      "name": "Posts",
      "documentSecurity": true,
      "permissions": ["read(\"any\")", "create(\"any\")"],
      "idMaxLength": 48,
      "attributes": [
        { "id": "title", "kind": "string", "required": true },
        { "id": "content", "kind": "string" },
        {
          "id": "author",
          "kind": "relationship",
          "required": true,
          "relationship": {
            "relatedCollection": "users",
            "kind": "manytoone",
            "side": "parent",
            "onDelete": "restrict"
          }
        }
      ],
      "indexes": [
        {
          "id": "full_text_content",
          "kind": "fulltext",
          "attributes": ["content"]
        }
      ]
    }
  ]
}
